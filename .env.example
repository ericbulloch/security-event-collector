# Security Event Collector — configuration
#
# Copy this file to .env and fill in the values before running.
#
#   cp .env.example .env       (Linux / macOS)
#   copy .env.example .env     (Windows)
#
# .env is gitignored so credentials stay local.

# ── Required ──────────────────────────────────────────────────────────────────

# URL of the security-event-correlator API (no trailing slash).
COLLECTOR_API_URL=http://localhost:8000

# API key issued by the correlator's seed script.
# Retrieve it by running in the correlator project:
#   python scripts/seed_dev.py
COLLECTOR_API_KEY=your-api-key-here

# ── Source identification ──────────────────────────────────────────────────────

# Value placed in the 'source' field of every event sent to the correlator.
# Defaults to the machine's hostname — override if the hostname is not
# meaningful (e.g. inside a container or behind NAT).
# COLLECTOR_SOURCE=my-web-server-01

# ── Tuning ────────────────────────────────────────────────────────────────────

# Seconds between log poll cycles. Lower = lower latency, higher CPU.
# COLLECTOR_POLL_INTERVAL=2

# Maximum number of events sent to the API per flush pass.
# Stay below the correlator's per-minute rate limit.
# COLLECTOR_BATCH_SIZE=25

# Per-request HTTP timeout in seconds.
# COLLECTOR_REQUEST_TIMEOUT=10

# Log verbosity: DEBUG | INFO | WARNING | ERROR
# COLLECTOR_LOG_LEVEL=INFO

# ── Local buffer ──────────────────────────────────────────────────────────────

# Path to the SQLite database used to buffer events when the API is unreachable.
# Defaults to collector.db in the working directory.
# COLLECTOR_DB_PATH=collector.db

# ── Linux log paths ───────────────────────────────────────────────────────────
# Defaults are standard Debian/Ubuntu paths.
# RHEL/CentOS users: change AUTH_LOG to /var/log/secure (AUDIT_LOG is the same).

# COLLECTOR_AUTH_LOG=/var/log/auth.log
# COLLECTOR_UFW_LOG=/var/log/ufw.log
# COLLECTOR_AUDIT_LOG=/var/log/audit/audit.log

# ── Windows log paths ─────────────────────────────────────────────────────────
# The Security Event Log is queried via wevtutil — no path needed.
# The Firewall log must be enabled separately (see README).

# COLLECTOR_WINDOWS_FIREWALL_LOG=C:\Windows\System32\LogFiles\Firewall\pfirewall.log
